    },
    "type": {
      "type": "string",
      "enum": [
        "stake",
        "win",
        "loss"
      ]
    },
    "amount": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "tx_signature": {
      "type": "string"
    }
  },
  "required": [
    "user_id",
    "type",
    "amount",
    "description"
  ]
}